{
    "tasks": {
        "version": "2.0.0",
        "tasks": [ 
            { // Full build from Markdown to pdf
                "label": "Build PDF from markdown sources",
                "type": "shell",
                "command": "${workspaceFolder}/build.sh",
                "group": {
                    "kind": "build",
                    "isDefault": true
                },
                "problemMatcher": []
            },
            { // Partial build from Markdown to TeX
                "label": "markdown 2 tex build",
                "type": "shell",
                "command": "${workspaceFolder}/m2t.sh",
                "group": {
                    "kind": "build",
                    "isDefault": false
                },
                "problemMatcher": []
            },
            { // Partial build from TeX to pdf
                "label": "tex 2 pdf build",
                "type": "shell",
                "command": "${workspaceFolder}/t2p.sh",
                "group": {
                    "kind": "build",
                    "isDefault": false
                },
                "problemMatcher": []
            },
            { // Clean build from Markdown to pdf
                "label": "clean build",
                "type": "shell",
                "command": "${workspaceFolder}/clean-build.sh",
                "group": {
                    "kind": "build",
                    "isDefault": false
                },
                "problemMatcher": []
            },
            { // Build and serve MKdocs site locally
                "label": "MKdocs serve",
                "type": "shell",
                "command": "mkdocs serve",
                "group": {
                    "kind": "build",
                    "isDefault": false
                },
                "problemMatcher": []
            },
        ]
    },
    "keybindings": [
        {
            "key": "ctrl+shift+b",
            "command": "workbench.action.runTask",
            "args": "build"
        }
    ],
    "latex-workshop.latex.autoBuild.run": "never",
    "markdownlint.config": {
        "MD041": false,
        "MD046": false,
        "MD049": { "style": "asterisk" },
        "MD050": { "style": "asterisk" },
    },
    "[markdown]": {
        "editor.formatOnSave": true,
        "editor.formatOnPaste": true
    },
}